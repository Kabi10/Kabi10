# Vercel Environment Variables Required
# Copy these to your Vercel project settings: https://vercel.com/agrimarket/settings/environment-variables

# Node Environment
NODE_ENV=production

# Supabase Database
SUPABASE_URL=https://lxsbdluguyaaxzaeovwx.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# JWT Secret (generate with: openssl rand -base64 32)
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# SMS Provider (for OTP)
# Option 1: Twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+94771234567

# Option 2: AWS SNS
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-south-1

# AWS S3 (for image uploads)
AWS_S3_BUCKET=agrimarket-images
AWS_S3_REGION=ap-south-1

# API Configuration
API_VERSION=v1
PORT=3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Database Mock Mode (NEVER enable in production)
MOCK_DB=false
