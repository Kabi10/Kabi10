{
  "version": 2,
  "functions": {
    "api/app.js": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/v1/market-prices/refresh-live",
      "schedule": "0 6 * * *"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/app.js"
    },
    {
      "src": "/(.*)",
      "dest": "/api/app.js"
    }
  ]
}
