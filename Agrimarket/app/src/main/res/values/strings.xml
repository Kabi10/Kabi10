    <!-- FAQ Screen -->
    <string name="faq_title">FAQ</string>
    <string name="faq_q1">How do I create a listing?</string>
    <string name="faq_a1">Go to Home screen, tap the \'+\' button, fill in the details, add photos, and submit.</string>
    <string name="faq_q2">How do I place an order?</string>
    <string name="faq_a2">Browse listings, select a product, tap \'Place Order\', enter quantity, and confirm.</string>
    <string name="faq_q3">How do I contact a seller?</string>
    <string name="faq_a3">Open the listing, tap \'Contact Seller\' to start a chat conversation.</string>
    <string name="faq_q4">How do I track my order?</string>
    <string name="faq_a4">Go to Transactions screen, select your order to view status and details.</string>
    <string name="faq_q5">What if I\'m offline?</string>
    <string name="faq_a5">The app works offline. Your changes will sync automatically when you\'re back online.</string>

