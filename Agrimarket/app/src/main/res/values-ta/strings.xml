    <!-- FAQ Screen -->
    <string name="faq_title">அடிக்கடி கேட்கப்படும் கேள்விகள்</string>
    <string name="faq_q1">பட்டியலை எவ்வாறு உருவாக்குவது?</string>
    <string name="faq_a1">முகப்பு திரைக்குச் செல்லவும், \'+\' பொத்தானைத் தட்டவும், விவரங்களை நிரப்பவும், புகைப்படங்களைச் சேர்க்கவும், சமர்ப்பிக்கவும்.</string>
    <string name="faq_q2">ஆர்டரை எவ்வாறு வைப்பது?</string>
    <string name="faq_a2">பட்டியல்களை உலாவவும், ஒரு தயாரிப்பைத் தேர்ந்தெடுக்கவும், \'ஆர்டர் செய்யவும்\' என்பதைத் தட்டவும், அளவை உள்ளிடவும், உறுதிப்படுத்தவும்.</string>
    <string name="faq_q3">விற்பனையாளரை எவ்வாறு தொடர்பு கொள்வது?</string>
    <string name="faq_a3">பட்டியலைத் திறக்கவும், அரட்டை உரையாடலைத் தொடங்க \'விற்பனையாளரைத் தொடர்பு கொள்ளவும்\' என்பதைத் தட்டவும்.</string>
    <string name="faq_q4">எனது ஆர்டரை எவ்வாறு கண்காணிப்பது?</string>
    <string name="faq_a4">பரிவர்த்தனைகள் திரைக்குச் செல்லவும், நிலை மற்றும் விவரங்களைக் காண உங்கள் ஆர்டரைத் தேர்ந்தெடுக்கவும்.</string>
    <string name="faq_q5">நான் ஆஃப்லைனில் இருந்தால் என்ன?</string>
    <string name="faq_a5">பயன்பாடு ஆஃப்லைனில் வேலை செய்கிறது. நீங்கள் மீண்டும் ஆன்லைனில் இருக்கும்போது உங்கள் மாற்றங்கள் தானாகவே ஒத்திசைக்கப்படும்.</string>

