    <!-- Privacy Screen -->
    <string name="privacy_title">தனியுரிமைக் கொள்கை</string>
    <string name="privacy_last_updated">கடைசியாக புதுப்பிக்கப்பட்டது: ஜனவரி 2026</string>
    <string name="privacy_info_collect_title">நாங்கள் சேகரிக்கும் தகவல்</string>
    <string name="privacy_info_collect_content">உங்கள் தொலைபேசி எண், பெயர், இருப்பிடம் மற்றும் பட்டியல் விவரங்கள் உள்ளிட்ட நேரடியாக வழங்கும் தகவல்களை நாங்கள் சேகரிக்கிறோம். எங்கள் சேவைகளை மேம்படுத்த பயன்பாட்டு தரவையும் சேகரிக்கிறோம்.</string>
    <string name="privacy_info_use_title">உங்கள் தகவலை நாங்கள் எவ்வாறு பயன்படுத்துகிறோம்</string>
    <string name="privacy_info_use_content">உங்கள் தகவல் பின்வருவனவற்றுக்கு பயன்படுத்தப்படுகிறது: எங்கள் சேவைகளை வழங்க மற்றும் பராமரிக்க, விவசாயிகளை வாங்குபவர்களுடன் இணைக்க, பரிவர்த்தனைகள் பற்றிய அறிவிப்புகளை அனுப்ப, பயனர் அனுபவத்தை மேம்படுத்த.</string>
    <string name="privacy_data_security_title">தரவு பாதுகாப்பு</string>
    <string name="privacy_data_security_content">உங்கள் தரவைப் பாதுகாக்க தொழில்துறை-தரமான பாதுகாப்பு நடவடிக்கைகளை செயல்படுத்துகிறோம். இதில் முக்கியமான தகவல்களின் குறியாக்கம் மற்றும் பாதுகாப்பான தரவு சேமிப்பு நடைமுறைகள் அடங்கும்.</string>
    <string name="privacy_data_sharing_title">தரவு பகிர்வு</string>
    <string name="privacy_data_sharing_content">உங்கள் தனிப்பட்ட தகவல்களை விற்க மாட்டோம். பரிவர்த்தனைகளுக்கு தேவையான அளவு மற்ற பயனர்களுடன் உங்கள் தகவலைப் பகிரலாம் (எ.கா., வாங்குபவர்கள்/விற்பனையாளர்களுடன் தொடர்பு விவரங்களைப் பகிர்வது).</string>
    <string name="privacy_your_rights_title">உங்கள் உரிமைகள்</string>
    <string name="privacy_your_rights_content">உங்கள் தனிப்பட்ட தகவல்களை அணுக, புதுப்பிக்க அல்லது நீக்க உங்களுக்கு உரிமை உள்ளது. பயன்பாட்டு அமைப்புகள் மூலம் அல்லது எங்கள் ஆதரவு குழுவை தொடர்பு கொண்டு உங்கள் தரவை நிர்வகிக்கலாம்.</string>
    <string name="privacy_contact_title">எங்களை தொடர்பு கொள்ளுங்கள்</string>
    <string name="privacy_contact_content">தனியுரிமை தொடர்பான கேள்விகள் அல்லது கவலைகளுக்கு, privacy@agrimarket.lk இல் எங்களை தொடர்பு கொள்ளுங்கள்</string>

    <!-- Terms Screen -->
    <string name="terms_title">சேவை விதிமுறைகள்</string>
    <string name="terms_last_updated">கடைசியாக புதுப்பிக்கப்பட்டது: ஜனவரி 2026</string>
    <string name="terms_acceptance_title">1. விதிமுறைகளை ஏற்றுக்கொள்ளுதல்</string>
    <string name="terms_acceptance_content">Agrimarket ஐ பயன்படுத்துவதன் மூலம், இந்த சேவை விதிமுறைகளை ஏற்றுக்கொள்கிறீர்கள். நீங்கள் ஒப்புக்கொள்ளவில்லை என்றால், பயன்பாட்டை பயன்படுத்த வேண்டாம்.</string>
    <string name="terms_accounts_title">2. பயனர் கணக்குகள்</string>
    <string name="terms_accounts_content">கணக்கை உருவாக்கும் போது நீங்கள் துல்லியமான தகவல்களை வழங்க வேண்டும். உங்கள் கணக்கின் பாதுகாப்பையும், உங்கள் கணக்கின் கீழ் நடக்கும் அனைத்து செயல்பாடுகளுக்கும் நீங்கள் பொறுப்பு.</string>
    <string name="terms_conduct_title">3. சந்தை நடத்தை</string>
    <string name="terms_conduct_content">பயனர்கள் விற்பனை செய்ய உரிமை உள்ள விவசாய தயாரிப்புகளை மட்டுமே பட்டியலிட ஒப்புக்கொள்கின்றனர். அனைத்து பட்டியல்களும் துல்லியமாகவும் தவறாக வழிநடத்தாததாகவும் இருக்க வேண்டும். மோசடி செயல்பாடு கணக்கு நிறுத்தத்தில் விளையும்.</string>
    <string name="terms_transactions_title">4. பரிவர்த்தனைகள்</string>
    <string name="terms_transactions_content">Agrimarket விவசாயிகள் மற்றும் வாங்குபவர்களுக்கு இடையே இணைப்புகளை எளிதாக்குகிறது ஆனால் உண்மையான பரிவர்த்தனைகளுக்கு பொறுப்பல்ல. பயனர்கள் தங்கள் சொந்த ஆபத்தில் பரிவர்த்தனை செய்கிறார்கள், கவனமாக இருக்க வேண்டும்.</string>
    <string name="terms_liability_title">5. பொறுப்பின் வரம்பு</string>
    <string name="terms_liability_content">Agrimarket உத்தரவாதங்கள் இல்லாமல் "அப்படியே" வழங்கப்படுகிறது. தளத்தின் பயன்பாட்டிலிருந்து எழும் மறைமுக, தற்செயல் அல்லது விளைவு சேதங்களுக்கு நாங்கள் பொறுப்பல்ல.</string>
    <string name="terms_contact_title">6. தொடர்பு</string>
    <string name="terms_contact_content">இந்த விதிமுறைகள் பற்றிய கேள்விகளுக்கு, எங்களை support@agrimarket.lk இல் தொடர்பு கொள்ளுங்கள்</string>

