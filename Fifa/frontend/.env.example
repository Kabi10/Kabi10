# ── Supabase (optional for MVP — events still display via client-side detection) ──
# Create a free project at https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Server-only (for backend writes from Next.js API routes)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Feature flags ──────────────────────────────────────────────────────────────
# Comma-separated list of ESPN league slugs to monitor
# Defaults: fifa.world,uefa.champions,eng.1,esp.1,ger.1,ita.1,fra.1
NEXT_PUBLIC_LEAGUE_SLUGS=fifa.world,uefa.champions,eng.1,esp.1

# Poll interval in milliseconds (default: 30000)
NEXT_PUBLIC_POLL_INTERVAL_MS=30000
