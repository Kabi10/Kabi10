# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from your Supabase project → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Polling config ────────────────────────────────────────────────────────────
# Comma-separated ESPN league slugs
LEAGUE_SLUGS=fifa.world,uefa.champions,eng.1,esp.1,ger.1,ita.1,fra.1

# Seconds between polls when live matches are active
POLL_INTERVAL_LIVE=60

# Seconds between polls when no live matches
POLL_INTERVAL_IDLE=120
