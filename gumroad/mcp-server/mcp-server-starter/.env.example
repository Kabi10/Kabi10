# ─────────────────────────────────────────────
# MCP Server Starter Kit — Environment Config
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Auth ──────────────────────────────────────
# Set AUTH_ENABLED=true when deploying via SSE.
# Leave false for local stdio use (Claude Desktop / Cursor).
AUTH_ENABLED=false
API_KEY=change-me-before-deploying

# ── Transport ─────────────────────────────────
# stdio  → Claude Desktop, Cursor (local process)
# sse    → HTTP server deployment
TRANSPORT=stdio

# ── Database ──────────────────────────────────
# Path to SQLite file. Swap for a connection string if using Postgres.
DB_PATH=./data/data.db

# ── Filesystem ────────────────────────────────
# All file operations are sandboxed to this directory.
WORKSPACE_DIR=./workspace

# ── External APIs ─────────────────────────────
# Required only if using get_current_weather with a paid provider.
# The default weather tool uses Open-Meteo (free, no key needed).
OPENWEATHER_API_KEY=

# Timeout in seconds for external HTTP requests.
EXTERNAL_API_TIMEOUT=10

# ── Server metadata ───────────────────────────
SERVER_NAME=mcp-server-starter
SERVER_VERSION=1.0.0
