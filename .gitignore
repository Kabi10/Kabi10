# ===================================================================
# WORKSPACE-LEVEL .GITIGNORE FOR DEVELOPMENT WORKSPACE
# ===================================================================

# Security - Never commit these
**/credentials.*
**/*.key
**/*.pem
**/.env
**/.env.*
!**/.env.example
!**/.env.template
**/secrets.*
**/config/private.*

# ===================================================================
# IDE AND EDITOR FILES
# ===================================================================
.vscode/
.idea/
*.swp
*.swo
*.sublime-*
.DS_Store
Thumbs.db
*.tmp
*.temp

# ===================================================================
