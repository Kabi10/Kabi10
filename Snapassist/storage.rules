rules_version = '2';

// Firebase Storage Security Rules for Snapassist
// These rules restrict access so that only authenticated users can read/write their own shots

service firebase.storage {
  match /b/{bucket}/o {
    // Rules for the shots directory
    match /shots/{userId}/{allPaths=**} {
      // Allow read and write access only if:
      // 1. User is authenticated (request.auth != null)
      // 2. The authenticated user's UID matches the userId in the path
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Deny access to all other paths
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}

// How to deploy these rules:
// 1. Install Firebase CLI: npm install -g firebase-tools
// 2. Login: firebase login
// 3. Initialize project: firebase init storage
// 4. Replace the generated storage.rules with this content
// 5. Deploy: firebase deploy --only storage

// Security features:
// - Only authenticated users can access the storage
// - Users can only access their own folder (shots/{their-uid}/)
// - No anonymous access allowed
// - Path-based security ensures isolation between users
// - Supports nested paths within user folders (shots/{uid}/subfolder/file.jpg)