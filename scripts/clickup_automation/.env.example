# ClickUp API Configuration
# Get your API token from: https://app.clickup.com/settings/apps
CLICKUP_API_TOKEN=pk_your_api_token_here

# Get your Space ID from the ClickUp URL when viewing your space
# Example: https://app.clickup.com/12345678/v/li/90123456
# Space ID would be: 12345678
CLICKUP_SPACE_ID=your_space_id_here

# Optional: Team ID (if you need to create spaces programmatically)
CLICKUP_TEAM_ID=your_team_id_here

